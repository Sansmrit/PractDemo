HelloWorld.java
public class HelloWorld {
    public static void main(String[] args) {
        System.out.println("Hello World from Docker Container");
    }
}
Dockerfile
FROM eclipse-temurin:17

COPY HelloWorld.java /app/HelloWorld.java

WORKDIR /app

RUN javac HelloWorld.java

CMD ["java", "HelloWorld"]

docker build -t javaapp .
docker login

docker images
docker run -it myapp:v1 sh
echo "" > newfile.txt

docker ps -a

docker commit ___ myapp:v2





